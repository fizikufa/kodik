<!doctype html>
<html lang="ru" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>KodikRouter Chat</title>
  <link href="https://api.fontshare.com/v2/css?f=satoshi@400,500,700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/marked/12.0.0/marked.min.js"></script>
  <style>
    :root,[data-theme=dark]{
      --bg:#171614;--surface:#1c1b19;--surface2:#201f1d;--border:#393836;
      --divider:#262523;--text:#cdccca;--muted:#797876;--faint:#5a5957;
      --primary:#4f98a3;--primary-hover:#227f8b;--danger:#d163a7;
      --radius:.6rem;--font:Satoshi,system-ui,sans-serif;
    }
    *{box-sizing:border-box}
    html,body{margin:0;height:100%;font-family:var(--font);background:var(--bg);color:var(--text)}
    body{display:flex;height:100dvh;overflow:hidden}

    /* History */
    .history{width:240px;flex-shrink:0;background:var(--surface);border-right:1px solid var(--divider);display:flex;flex-direction:column}
    .history-head{padding:.9rem 1rem;border-bottom:1px solid var(--divider);display:flex;justify-content:space-between;align-items:center}
    .history-head h2{margin:0;font-size:.78rem;text-transform:uppercase;color:var(--muted);letter-spacing:.05em}
    .history-list{flex:1;overflow-y:auto;padding:.5rem}
    .chat-item{padding:.55rem .7rem;border-radius:var(--radius);cursor:pointer;font-size:.88rem;display:flex;justify-content:space-between;gap:.5rem;align-items:center}
    .chat-item:hover{background:var(--surface2)}
    .chat-item.active{background:#313b3b;color:var(--primary)}
    .chat-item-title{overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1}
    .chat-item-del{opacity:0;color:var(--faint);background:none;border:none;cursor:pointer;padding:.2rem}
    .chat-item:hover .chat-item-del{opacity:1}
    .chat-item-del:hover{color:var(--danger)}

    /* Sidebar */
    .sidebar{width:300px;flex-shrink:0;background:var(--surface);border-right:1px solid var(--divider);padding:1rem;overflow-y:auto}
    .sidebar h3{font-size:.75rem;text-transform:uppercase;color:var(--muted);letter-spacing:.05em;margin:1.2rem 0 .5rem}
    .sidebar h3:first-child{margin-top:0}
    .sidebar label{display:block;font-size:.8rem;color:var(--muted);margin-bottom:.25rem}
    input,select,textarea,button{font:inherit;color:inherit;box-sizing:border-box;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);padding:.5rem .7rem;outline:none;width:100%}
    input:focus,select:focus,textarea:focus{border-color:var(--primary)}
    textarea{resize:vertical}
    button{cursor:pointer;background:var(--surface2);transition:.15s;width:auto}
    button:hover{border-color:var(--primary);color:var(--primary)}
    button.primary{background:var(--primary);color:#1c1b19;font-weight:600;border-color:var(--primary)}
    button.primary:hover{background:var(--primary-hover);color:#fff}
    button.primary:disabled{opacity:.5;cursor:not-allowed}
    .row{display:grid;grid-template-columns:1fr 1fr;gap:.5rem}
    .field{margin-bottom:.6rem}
    .preset-btn{width:100%;text-align:left;padding:.4rem .6rem;font-size:.85rem;margin-bottom:.2rem;border-color:transparent;background:transparent}
    .preset-btn:hover{background:var(--surface2)}
    .usage-box{background:var(--surface2);padding:.6rem .7rem;border-radius:var(--radius);font-size:.78rem;color:var(--muted)}
    .usage-box span{color:var(--text)}
    .usage-bar{height:5px;background:var(--divider);border-radius:99px;margin-top:.3rem;overflow:hidden}
    .usage-bar div{height:100%;background:var(--primary);transition:.3s}

    /* Main */
    .main{flex:1;display:flex;flex-direction:column;min-width:0}
    .topbar{padding:.7rem 1.2rem;border-bottom:1px solid var(--divider);display:flex;justify-content:space-between;align-items:center;background:var(--surface)}
    .topbar h1{margin:0;font-size:.95rem}
    .topbar-right{display:flex;gap:.5rem;align-items:center;font-size:.8rem;color:var(--muted)}
    .topbar-right a{color:var(--muted);text-decoration:none;padding:.3rem .6rem;border:1px solid var(--border);border-radius:var(--radius)}
    .topbar-right a:hover{border-color:var(--primary);color:var(--primary)}
    .body{flex:1;overflow-y:auto;padding:1.2rem;display:flex;flex-direction:column;gap:.8rem}
    .message{display:flex;flex-direction:column;gap:.3rem;max-width:820px;width:100%}
    .message.user{align-self:flex-end;align-items:flex-end}
    .message.assistant{align-self:flex-start}
    .msg-meta{font-size:.7rem;color:var(--faint);text-transform:uppercase;letter-spacing:.05em}
    .msg-bubble{padding:.8rem 1rem;border-radius:1rem;border:1px solid var(--border)}
    .user .msg-bubble{background:#313b3b;border-color:#3a4848;border-bottom-right-radius:.3rem}
    .assistant .msg-bubble{background:var(--surface2);border-bottom-left-radius:.3rem}
    .msg-bubble p{margin:.3em 0}
    .msg-bubble pre{background:#0d1117;padding:.8em;border-radius:.5em;overflow-x:auto;font-size:.85em}
    .msg-bubble code:not(pre code){background:rgba(255,255,255,.08);padding:.1em .3em;border-radius:3px;font-size:.85em}
    .msg-bubble ul,.msg-bubble ol{padding-left:1.4em}
    .msg-attach-badge{font-size:.7rem;color:var(--muted);margin-top:.3rem;display:flex;gap:.4rem;flex-wrap:wrap}
    .msg-attach-badge span{background:var(--surface2);border:1px solid var(--border);border-radius:99px;padding:.1rem .5rem}

    /* Composer */
    .composer{padding:.8rem 1.2rem;border-top:1px solid var(--divider);background:var(--surface)}
    .composer textarea{min-height:60px;max-height:200px;margin-bottom:.5rem}

    /* Attachment preview */
    .attach-list{display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:.5rem}
    .attach-chip{display:flex;align-items:center;gap:.4rem;background:var(--surface2);border:1px solid var(--border);border-radius:99px;padding:.2rem .6rem .2rem .5rem;font-size:.8rem;max-width:200px}
    .attach-chip .attach-name{overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1}
    .attach-chip .attach-rm{background:none;border:none;cursor:pointer;color:var(--faint);padding:0;width:auto;font-size:.9rem;line-height:1}
    .attach-chip .attach-rm:hover{color:var(--danger)}
    .attach-chip .attach-icon{font-size:.9rem}

    .composer-foot{display:flex;justify-content:space-between;align-items:center;gap:.5rem}
    .composer-foot-left{display:flex;align-items:center;gap:.5rem}
    .attach-btn{padding:.4rem .6rem;font-size:.85rem}

    .empty{flex:1;display:flex;align-items:center;justify-content:center;color:var(--muted)}
    .thinking{display:flex;gap:4px}
    .thinking span{width:6px;height:6px;background:var(--primary);border-radius:50%;animation:b 1.2s infinite}
    .thinking span:nth-child(2){animation-delay:.2s}
    .thinking span:nth-child(3){animation-delay:.4s}
    @keyframes b{0%,80%,100%{opacity:.2}40%{opacity:1}}
    ::-webkit-scrollbar{width:6px}
    ::-webkit-scrollbar-thumb{background:var(--border);border-radius:99px}

    #fileInput{display:none}
    .upload-progress{font-size:.75rem;color:var(--muted);margin-bottom:.3rem;min-height:1em}
  </style>
</head>
<body>

<aside class="history">
  <div class="history-head">
    <h2>Чаты</h2>
    <button id="newChatBtn" title="Новый чат" style="padding:.3rem .55rem">＋</button>
  </div>
  <div class="history-list" id="historyList"></div>
</aside>

<aside class="sidebar">
  <h3>Модель</h3>
  <div class="field">
    <div style="display:flex;gap:.4rem">
      <input id="modelInput" value="openai/gpt-4o-mini">
      <button id="loadModelsBtn" title="Загрузить список">⟳</button>
    </div>
    <select id="modelSelect" style="display:none;margin-top:.4rem"></select>
  </div>

  <div class="row">
    <div class="field"><label>Температура</label><input id="tempInput" type="number" min="0" max="2" step="0.05" value="0.7"></div>
    <div class="field"><label>Max tokens</label><input id="maxTokInput" type="number" value="2048"></div>
  </div>
  <label style="display:flex;align-items:center;gap:.4rem;font-size:.85rem;cursor:pointer">
    <input type="checkbox" id="streamCheck" checked style="width:auto"> Streaming
  </label>

  <h3>Системный промпт</h3>
  <textarea id="systemInput" rows="3" placeholder="Вы — полезный ассистент..."></textarea>
  <div style="display:flex;gap:.3rem;margin-top:.4rem">
    <button id="savePresetBtn" style="flex:1">Сохранить</button>
    <button id="applyPromptBtn" style="flex:1">Применить</button>
  </div>
  <div id="presetList" style="margin-top:.5rem"></div>

  <h3>Использование</h3>
  <div class="usage-box" id="usageBox">…</div>
</aside>

<main class="main">
  <header class="topbar">
    <h1 id="chatTitleEl">KodikRouter Chat</h1>
    <div class="topbar-right">
      <span id="userLabel"></span>
      <a href="/admin" id="adminLink" style="display:none">Админ</a>
      <a href="#" id="logoutLink">Выйти</a>
    </div>
  </header>

  <section class="body" id="chatBody">
    <div class="empty" id="emptyState">Выберите чат или начните новый ✦</div>
  </section>

  <section class="composer">
    <div class="upload-progress" id="uploadProgress"></div>
    <div class="attach-list" id="attachList"></div>
    <textarea id="userInput" placeholder="Сообщение… Ctrl+Enter для отправки"></textarea>
    <div class="composer-foot">
      <div class="composer-foot-left">
        <button class="attach-btn" id="attachBtn" title="Прикрепить файл">📎</button>
        <input type="file" id="fileInput"
          accept=".pdf,.docx,.xlsx,.xls,.csv,.txt,.png,.jpg,.jpeg,.webp,.gif"
          multiple>
        <button id="stopBtn" disabled>⏹</button>
      </div>
      <div style="display:flex;gap:.4rem">
        <button id="sendBtn" class="primary">Отправить</button>
      </div>
    </div>
  </section>
</main>

<script>
const $ = id => document.getElementById(id);
const state = {
  chats: [], activeChatId: null, messages: [], controller: null,
  presets: [],
  attachments: [],
};

marked.setOptions({breaks: true, gfm: true});
const renderer = new marked.Renderer();
renderer.code = function(code, lang) {
  let h;
  try { h = lang && hljs.getLanguage(lang) ? hljs.highlight(code,{language:lang}).value : hljs.highlightAuto(code).value; }
  catch { h = escapeHtml(code); }
  return `<pre><code class="hljs">${h}</code></pre>`;
};
marked.use({renderer});

function escapeHtml(s) {
  return s.replace(/[&<>"]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));
}

async function api(url, opts = {}) {
  const r = await fetch(url, {headers:{'Content-Type':'application/json'}, ...opts});
  if (r.status === 401) { location.href = '/login'; throw new Error('auth'); }
  const data = await r.json().catch(() => ({}));
  if (!r.ok) throw new Error(data.detail || r.status);
  return data;
}

// ─── File attachments ───
$('attachBtn').onclick = () => $('fileInput').click();

$('fileInput').addEventListener('change', async e => {
  const files = [...e.target.files];
  if (!files.length) return;
  e.target.value = '';

  for (const file of files) {
    $('uploadProgress').textContent = `Загрузка: ${file.name}…`;
    try {
      const fd = new FormData();
      fd.append('file', file);
      const r = await fetch('/api/chat/upload-file', {method:'POST', body: fd});
      if (r.status === 401) { location.href = '/login'; return; }
      const data = await r.json();
      if (!r.ok) { alert(`Ошибка: ${data.detail || r.status}`); continue; }
      state.attachments.push(data);
      renderAttachList();
    } catch(err) {
      alert(`Не удалось загрузить ${file.name}: ${err.message}`);
    }
  }
  $('uploadProgress').textContent = '';
});

function renderAttachList() {
  const wrap = $('attachList');
  wrap.innerHTML = state.attachments.map((a, i) => {
    const icon = a.type === 'image' ? '🖼' : '📄';
    return `<div class="attach-chip">
      <span class="attach-icon">${icon}</span>
      <span class="attach-name" title="${escapeHtml(a.filename)}">${escapeHtml(a.filename)}</span>
      <button class="attach-rm" data-idx="${i}" title="Удалить">✕</button>
    </div>`;
  }).join('');
  wrap.querySelectorAll('.attach-rm').forEach(b => {
    b.onclick = () => {
      state.attachments.splice(+b.dataset.idx, 1);
      renderAttachList();
    };
  });
}

// ─── Models ───
$('loadModelsBtn').onclick = async () => {
  try {
    const data = await api('/api/chat/models');
    const list = (data.data || data).map(m => typeof m === 'string' ? m : m.id).filter(Boolean).sort();
    const sel = $('modelSelect');
    sel.innerHTML = list.map(m => `<option>${m}</option>`).join('');
    sel.style.display = '';
    sel.onchange = () => $('modelInput').value = sel.value;
  } catch(e) { alert(e.message); }
};

// ─── Presets ───
async function loadPresets() {
  state.presets = await api('/api/chat/presets');
  const wrap = $('presetList');
  if (!state.presets.length) { wrap.innerHTML = ''; return; }
  wrap.innerHTML = state.presets.map(p =>
    `<div style="display:flex;gap:.3rem;margin-bottom:.2rem">
      <button class="preset-btn" data-pid="${p.id}" style="flex:1">${escapeHtml(p.name)}</button>
      <button data-pdel="${p.id}" style="padding:.3rem .5rem;color:var(--danger);border-color:transparent;background:none">✕</button>
    </div>`
  ).join('');
  wrap.querySelectorAll('[data-pid]').forEach(b => {
    b.onclick = () => { const p = state.presets.find(x => x.id == b.dataset.pid); if (p) $('systemInput').value = p.content; };
  });
  wrap.querySelectorAll('[data-pdel]').forEach(b => {
    b.onclick = async () => { await api(`/api/chat/presets/${b.dataset.pdel}`, {method:'DELETE'}); loadPresets(); };
  });
}

$('savePresetBtn').onclick = async () => {
  const content = $('systemInput').value.trim();
  if (!content) return;
  const name = prompt('Название пресета:');
  if (!name) return;
  await api('/api/chat/presets', {method:'POST', body: JSON.stringify({name, content})});
  loadPresets();
};

$('applyPromptBtn').onclick = async () => {
  if (!state.activeChatId) return;
  await api(`/api/chat/chats/${state.activeChatId}`, {method:'PATCH', body: JSON.stringify({system_prompt: $('systemInput').value, model: $('modelInput').value})});
};

// ─── Chat list ───
async function loadChats() {
  state.chats = await api('/api/chat/chats');
  renderChatList();
  if (state.chats.length && !state.activeChatId) await selectChat(state.chats[0].id);
  else if (state.activeChatId) await selectChat(state.activeChatId);
  else renderMessages();
}

function renderChatList() {
  const list = $('historyList');
  if (!state.chats.length) {
    list.innerHTML = `<div style="padding:1.5rem 1rem;text-align:center;color:var(--faint);font-size:.85rem">Нет чатов</div>`;
    return;
  }
  list.innerHTML = state.chats.map(c =>
    `<div class="chat-item ${c.id==state.activeChatId?'active':''}" data-id="${c.id}">
      <span class="chat-item-title">${escapeHtml(c.title)}</span>
      <button class="chat-item-del" data-del="${c.id}">✕</button>
    </div>`
  ).join('');
  list.querySelectorAll('.chat-item').forEach(el => {
    el.onclick = e => { if (!e.target.dataset.del) selectChat(el.dataset.id); };
  });
  list.querySelectorAll('[data-del]').forEach(b => {
    b.onclick = async e => {
      e.stopPropagation();
      if (!confirm('Удалить чат?')) return;
      await api(`/api/chat/chats/${b.dataset.del}`, {method:'DELETE'});
      if (b.dataset.del == state.activeChatId) state.activeChatId = null;
      loadChats();
    };
  });
}

async function selectChat(id) {
  state.activeChatId = id;
  const chat = state.chats.find(c => c.id == id);
  if (chat) {
    $('chatTitleEl').textContent = chat.title;
    $('modelInput').value = chat.model;
    $('systemInput').value = chat.system_prompt;
  }
  state.messages = await api(`/api/chat/chats/${id}/messages`);
  renderChatList();
  renderMessages();
}

$('newChatBtn').onclick = async () => {
  const chat = await api('/api/chat/chats', {method:'POST', body: JSON.stringify({title:'Новый чат', model: $('modelInput').value, system_prompt: $('systemInput').value})});
  state.activeChatId = chat.id;
  await loadChats();
};

// ─── Messages ───
function renderMessages() {
  const body = $('chatBody');
  body.innerHTML = '';
  if (!state.messages.length) {
    body.innerHTML = '<div class="empty">Начните диалог ✦</div>';
    return;
  }
  state.messages.forEach(m => appendMessage(m.role, m.content, m.model));
  body.scrollTop = body.scrollHeight;
}

function appendMessage(role, content, meta) {
  const body = $('chatBody');
  const empty = body.querySelector('.empty');
  if (empty) empty.remove();
  const wrap = document.createElement('div');
  wrap.className = `message ${role}`;
  wrap.innerHTML = `
    <div class="msg-meta">${role}${meta ? ' · '+escapeHtml(meta) : ''}</div>
    <div class="msg-bubble">${role==='assistant' ? marked.parse(content) : escapeHtml(content)}</div>`;
  body.appendChild(wrap);
  body.scrollTop = body.scrollHeight;
  return wrap;
}

// ─── Send ───
$('userInput').addEventListener('keydown', e => {
  if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) send();
});

async function send() {
  const text = $('userInput').value.trim();
  if (!text && state.attachments.length === 0) return;

  if (!state.activeChatId) {
    const title = text.slice(0, 40) || (state.attachments[0]?.filename || 'Новый чат');
    const chat = await api('/api/chat/chats', {method:'POST', body: JSON.stringify({title, model: $('modelInput').value, system_prompt: $('systemInput').value})});
    state.activeChatId = chat.id;
    await loadChats();
  }

  const userWrap = appendMessage('user', text || '(вложение)', $('modelInput').value);
  if (state.attachments.length) {
    const badges = document.createElement('div');
    badges.className = 'msg-attach-badge';
    badges.innerHTML = state.attachments.map(a =>
      `<span>${a.type==='image'?'🖼':'📄'} ${escapeHtml(a.filename)}</span>`
    ).join('');
    userWrap.appendChild(badges);
  }

  $('userInput').value = '';
  $('sendBtn').disabled = true;
  $('stopBtn').disabled = false;

  const thinkNode = document.createElement('div');
  thinkNode.className = 'message assistant';
  thinkNode.innerHTML = '<div class="msg-meta">assistant</div><div class="msg-bubble"><div class="thinking"><span></span><span></span><span></span></div></div>';
  $('chatBody').appendChild(thinkNode);
  $('chatBody').scrollTop = $('chatBody').scrollHeight;

  const stream = $('streamCheck').checked;
  const controller = new AbortController();
  state.controller = controller;

  const attachmentsCopy = [...state.attachments];
  state.attachments = [];
  renderAttachList();

  try {
    const res = await fetch('/api/chat/completion', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({
        chat_id: state.activeChatId,
        content: text,
        attachments: attachmentsCopy,
        temperature: +$('tempInput').value,
        max_tokens: +$('maxTokInput').value,
        stream,
      }),
      signal: controller.signal,
    });

    if (!res.ok) {
      const d = await res.json().catch(() => ({}));
      throw new Error(d.detail || `HTTP ${res.status}`);
    }

    thinkNode.remove();
    const assistantNode = appendMessage('assistant', '', $('modelInput').value);
    const bubble = assistantNode.querySelector('.msg-bubble');

    if (!stream) {
      const data = await res.json();
      bubble.innerHTML = marked.parse(data.content);
    } else {
      const reader = res.body.getReader();
      const dec = new TextDecoder();
      let buf = '', full = '';
      while (true) {
        const {value, done} = await reader.read();
        if (done) break;
        buf += dec.decode(value, {stream: true});
        const parts = buf.split('\n\n');
        buf = parts.pop();
        for (const evt of parts) {
          for (const line of evt.split('\n')) {
            if (!line.startsWith('data:')) continue;
            const d = line.slice(5).trim();
            if (d === '[DONE]') continue;
            try {
              const obj = JSON.parse(d);
              if (obj.error) throw new Error(obj.error);
              if (obj.delta) { full += obj.delta; bubble.innerHTML = marked.parse(full); $('chatBody').scrollTop = $('chatBody').scrollHeight; }
            } catch {}
          }
        }
      }
    }

    await loadUsage();
    state.chats = await api('/api/chat/chats');
    renderChatList();
  } catch(e) {
    thinkNode.remove();
    appendMessage('assistant', e.message, $('modelInput').value);
  } finally {
    $('sendBtn').disabled = false;
    $('stopBtn').disabled = true;
    state.controller = null;
  }
}

$('sendBtn').onclick = send;
$('stopBtn').onclick = () => state.controller?.abort();

// ─── Usage ───
async function loadUsage() {
  try {
    const u = await api('/api/chat/me/usage');
    const rpmPct = Math.min(100, u.requests_last_minute / u.rpm_limit * 100);
    const budgetPct = Math.min(100, u.spent_this_month / u.monthly_budget * 100);
    $('usageBox').innerHTML = `
      <div>RPM <span>${u.requests_last_minute}/${u.rpm_limit}</span></div>
      <div class="usage-bar"><div style="width:${rpmPct}%"></div></div>
      <div style="margin-top:.4rem"><span>₽${u.spent_this_month.toFixed(4)} / ₽${u.monthly_budget.toFixed(2)}</span></div>
      <div class="usage-bar"><div style="width:${budgetPct}%;background:${budgetPct>80?'var(--danger)':'var(--primary)'}"></div></div>
      <div style="margin-top:.4rem;font-size:.72rem">Запросов всего: <span>${u.total_requests}</span></div>`;
  } catch {}
}

// ─── Init ───
async function init() {
  try {
    const me = await api('/api/auth/me');
    $('userLabel').textContent = me.username;
    if (me.is_admin) $('adminLink').style.display = '';
    if (me.default_system_prompt) $('systemInput').value = me.default_system_prompt;
  } catch { return; }
  await loadUsage();
  await loadPresets();
  await loadChats();
}

$('logoutLink').onclick = async e => {
  e.preventDefault();
  await fetch('/api/auth/logout', {method:'POST'});
  location.href = '/login';
};

init();
setInterval(loadUsage, 15000);
</script>
</body>
</html>
